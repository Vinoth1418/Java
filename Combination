import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner a=new Scanner(System.in);
		int b=a.nextInt();
		int c=a.nextInt();
		int res=1;
		int res1=1;
		int res2=b-c;
		int res3=1;
		for(int i=1;i<=b;i++){
		    res*=i;
		}
		for(int i=1;i<=c;i++){
		    res1*=i;
		}
		for(int i=1;i<=res2;i++){
		    res3*=i;
		}
		int result=res/(res1*res3);
		System.out.println(result);
	}
}
